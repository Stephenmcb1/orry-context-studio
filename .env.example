# .env.example — copy to .env.local and fill in values
# Never commit .env.local

# From your orry-context Supabase project settings → API
SUPABASE_URL=https://uiogkpytfnjewekeowgr.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Shared password for Stephen and Thilde to log into Context Studio
STUDIO_PASSWORD=choose-a-strong-password

# Random secret for HMAC session token signing — generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
STUDIO_SECRET=generate-a-32-byte-random-hex-string
